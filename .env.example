# Copie este archivo como ".env" en la raíz del proyecto si usa variables de entorno.
# NO suba ".env" a Git (está en .gitignore).
# E.D.A. carga `.env` al iniciar si tiene instalado `python-dotenv` (viene en requirements.txt).
#
# --- Groq / LLM remoto seguro (100 % opcional; por defecto E.D.A. usa Ollama local) ---
# Compatible con API estilo OpenAI: POST {BASE}/chat/completions
# Ejemplo Groq:
# EDA_REMOTE_LLM_ENABLED=1
# EDA_REMOTE_LLM_BASE_URL=https://api.groq.com/openai/v1
# EDA_REMOTE_LLM_MODEL=llama-3.1-8b-instant
# EDA_REMOTE_LLM_API_KEY=gsk_...
# EDA_REMOTE_SEARCH_MODE=1
# EDA_REMOTE_LLM_MODE=research_and_review
#
# Ejemplo genérico:
# EDA_REMOTE_LLM_ENABLED=1
# EDA_REMOTE_LLM_BASE_URL=https://api.openai.com/v1
# EDA_REMOTE_LLM_MODEL=gpt-4o-mini
# EDA_REMOTE_LLM_API_KEY=su_clave_aqui
# EDA_REMOTE_LLM_MODE=off
#
# Investigación segura (deep research): fuerza síntesis del contenido web solo en el LLM remoto.
# Requiere EDA_REMOTE_LLM_ENABLED=1 + URL/model/API key válidos.
# EDA_REMOTE_SEARCH_MODE=1
# Modos: off | fallback | research | code_review | research_and_review
#
# Ver comentarios en eda/config.py (REMOTE_LLM_*) para más detalle.
#
# --- Spotify Web API (opcional; sin esto sigue el modo escritorio con atajos) ---
# Crea una app en https://developer.spotify.com/ y añade Redirect URI exacta:
#   http://127.0.0.1:8888/callback
# Primera autenticación (abre navegador y guarda token en .cache/):
#   python scripts/spotify_login.py
#
# Solo Client ID (PKCE, recomendado para repo público — sin client secret en .env):
# EDA_SPOTIFY_CLIENT_ID=tu_client_id
# EDA_SPOTIFY_USE_PKCE=1
#
# O app "confidential" con secret (no subas el secret a Git):
# EDA_SPOTIFY_CLIENT_ID=tu_client_id
# EDA_SPOTIFY_CLIENT_SECRET=tu_client_secret
#
# EDA_SPOTIFY_REDIRECT_URI=http://127.0.0.1:8888/callback
# Scopes (fijados en código, no hace falta listarlos en .env): lectura de biblioteca, listas
# privadas, playback, dispositivos, “Tus me gusta”. Tras ampliar scopes, borrar
# .cache/spotify_token_cache.json y volver a:  python scripts/spotify_login.py
#
# NLU / confianza (opcional; ver docs/spotify_integration.md y config.py)
# EDA_SPOTIFY_CONF_AUTO=0.82
# EDA_SPOTIFY_CONF_AMBIG_LOW=0.5
# EDA_SPOTIFY_CACHE_TTL_SECONDS=900
# EDA_SPOTIFY_TRANSFER_REQUIRES_CONFIRM=1
# EDA_COMMAND_CONFIDENCE_THRESHOLD=0.78
#
# Desactivar Web API y forzar solo escritorio:
# EDA_SPOTIFY_WEB_API=0
#
# Desactivar login automático (sin spotify_login.py al fallar token / sin login si falta caché):
# EDA_SPOTIFY_AUTO_LOGIN=0
#
# Nota: control remoto de reproducción suele requerir Spotify Premium y un cliente abierto.
#
# --- Telegram (scripts `tools/bootstrap_v3.py`, `tools/operate_secure.py`) ---
# Para smoke tests desde terminal (NO es la configuración principal del asistente en marcha).
# TELEGRAM_TOKEN=123456:ABC...
# TELEGRAM_CHATID=tu_chat_id_numerico
#
# Control remoto desde la propia app: usa el comando en chat/GUI:
#   configurar móvil: telegram|<TOKEN>|<CHAT_ID>
# Eso guarda credenciales cifradas en config/mobile_connector.json (no edites ese JSON a mano salvo emergencia).
#
# --- Interfaz Obsidian src/ui_main.py ---
# EDA_UI_METRICS_MS=2000
# EDA_UI_HEADLESS=1
#
# --- Ollama (URLs se arman desde host:puerto; ver src/eda/config.py) ---
# EDA_OLLAMA_HOST=127.0.0.1
# EDA_OLLAMA_PORT=11434
# Alias soportados: OLLAMA_HOST, OLLAMA_PORT
# OLLAMA_MODEL=llama3.2:1b
# Alias: EDA_OLLAMA_MODEL
# Tras instalar Ollama:  ollama pull llama3.2:1b
# Liberar memoria de Ollama bajo presión RAM (1=activo, 0=desactivar):
# EDA_RELEASE_OLLAMA_MEMORY=1
#
# Backups Windows (ruta absoluta; vacío = fallback de ejemplo en config, no portable)
# EDA_BACKUP_PATH=C:\Users\TuUsuario\Documents\EDA_Backups
#
# --- OBS Studio WebSocket ---
# Contraseña del plugin obs-websocket se configura en src/eda/config.py (OBS_WS_*), no en .env por defecto.
