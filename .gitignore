# Python cache/bytecode
__pycache__/
*.py[cod]
*.pyo

# Virtual environments
.venv/
venv/
venv312/

# Spotify Web API — caché OAuth local (no subir tokens)
.cache/

# Runtime generated data
data/logs/
data/exports/
data/captures/
data/backups/
data/solutions/
data/suggestions/
temp/runtime/
temp/cache/

# Local memory/state (runtime)
data/memory/*.json
!data/memory/*.example.json

# OS/editor noise
.DS_Store
Thumbs.db
.vscode/
.idea/

# Secretos y entorno local (copiar .env.example → .env; no subir .env)
.env
.env.*
!.env.example

# Config local de herramientas (no forma parte del producto)
.continue/
.cursor/
.abacus.donotdelete

# Datastores runtime (no versionar estados locales)
data/memory/*.sqlite3
data/logs/*.jsonl
logs/*.log
backups/

